# =============================================================================
# config/mariadb/my.cnf
# Configuración MySQL/MariaDB optimizada para ERPNext multi-site
# =============================================================================
[mysqld]
character-set-client-handshake     = FALSE
character-set-server               = utf8mb4
collation-server                   = utf8mb4_unicode_ci

# ── Conexiones ────────────────────────────────────────────────────────────────
max_connections                    = 300
max_connect_errors                 = 1000000
wait_timeout                       = 600
interactive_timeout                = 600

# ── InnoDB (ajustar según RAM del servidor) ───────────────────────────────────
# Pequeño (4 GB RAM):  innodb_buffer_pool_size = 512M
# Mediano (8 GB RAM):  innodb_buffer_pool_size = 2G
# Grande (16 GB RAM):  innodb_buffer_pool_size = 6G
innodb_buffer_pool_size            = 512M
innodb_buffer_pool_instances       = 1
innodb_log_file_size               = 256M
innodb_log_buffer_size             = 64M
innodb_file_per_table              = 1
innodb_flush_log_at_trx_commit     = 1
innodb_flush_method                = O_DIRECT
innodb_io_capacity                 = 400
innodb_read_io_threads             = 4
innodb_write_io_threads            = 4

# ── Query cache (desactivado — Frappe lo maneja con Redis) ────────────────────
query_cache_type                   = 0
query_cache_size                   = 0

# ── Slow query log (activar en diagnóstico) ───────────────────────────────────
slow_query_log                     = 0
# slow_query_log_file              = /var/log/mysql/slow.log
# long_query_time                  = 2

# ── Binlog (activar si necesitas replicación) ─────────────────────────────────
# log_bin                          = /var/log/mysql/mysql-bin
# binlog_format                    = ROW
# expire_logs_days                 = 7

# ── Temp tables ───────────────────────────────────────────────────────────────
tmp_table_size                     = 64M
max_heap_table_size                = 64M

# ── Sort y join buffers ───────────────────────────────────────────────────────
sort_buffer_size                   = 4M
join_buffer_size                   = 4M
read_buffer_size                   = 2M
read_rnd_buffer_size               = 2M

[client]
default-character-set              = utf8mb4

[mysql]
default-character-set              = utf8mb4
